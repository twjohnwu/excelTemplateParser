# Copy to .env and adjust as needed. docker-compose reads it automatically.

# Redis connection (defaults to the redis service in docker-compose)
REDIS_URL=redis://redis:6379/0

# Filesystem root for runtime artefacts (redis AOF, configs, jobs).
# Mount this at a NAS or external drive if you want persistence across hosts.
DATA_DIR=./data

# Per-file upload ceiling, in megabytes. Requests exceeding this return 413.
MAX_UPLOAD_MB=50

# Number of RQ worker processes spawned by `python -m app.workers.run`.
RQ_WORKERS=4

# Per-subtask timeout (minutes). After this RQ kills the worker process.
JOB_TIMEOUT_MIN=10

# Re-download grace window after a successful ZIP fetch (minutes).
# Inside this window the job artefacts are retained for retry.
DOWNLOAD_GRACE_MINUTES=60

# Sweep undownloaded job artefacts after this many hours.
JOB_RETENTION_HOURS=24

# structlog level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
